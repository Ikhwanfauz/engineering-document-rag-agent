# Runtime mode
APP_ENV=development
LOG_LEVEL=INFO

# LLM provider and model will be selected during the model-selection checkpoint.
LLM_PROVIDER=
LLM_MODEL=
LLM_API_BASE=
LLM_API_KEY=

# Embeddings will be benchmarked before this value is finalized.
EMBEDDING_MODEL=

# Retrieval defaults; these may change after evaluation.
RETRIEVAL_TOP_K=5
MIN_RELEVANCE_SCORE=0.0

# Local paths
MANUALS_DIR=data/manuals
PROCESSED_DIR=data/processed
VECTOR_STORE_DIR=data/vector_store
DATABASE_PATH=database/engineering_document_ai.db

